{
  "name": "dungeon-crawler",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@dungeon/client",
    "build": "npm run build --workspace=@dungeon/client",
    "server": "npm run start --workspace=@dungeon/server",
    "server:dev": "npm run dev --workspace=@dungeon/server",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md,html,css}": "prettier --write"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3"
  }
}
